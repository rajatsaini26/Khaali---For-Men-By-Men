# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# ─── AI (Gemini) ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Database ─────────────────────────────────────────────
# SQLite (development — default)
SQLITE_DB_PATH=./khaali.db

# PostgreSQL (production — swap DB_DRIVER to 'postgres')
DB_DRIVER=sqlite
DATABASE_URL=postgresql://user:password@localhost:5432/khaali

# ─── App Version (version check endpoint) ─────────────────
APP_LATEST_VERSION_ANDROID=1.0.0
APP_MIN_SUPPORTED_ANDROID=1.0.0
APP_LATEST_VERSION_IOS=1.0.0
APP_MIN_SUPPORTED_IOS=1.0.0
