{
  "name": "khaali-api",
  "version": "1.0.0",
  "description": "Khaali — Fastify API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^11.0.2",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.41.0",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "pino-pretty": "^13.1.3",
    "semver": "^7.6.3",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/semver": "^7.5.8",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
